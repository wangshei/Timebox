# Copy to .env and fill in. Do not commit .env.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: production app URL. Set in Vercel (or your host) so magic links point to this URL.
# Example: VITE_SITE_URL=https://timebox-fawn.vercel.app
# VITE_SITE_URL=

# Admin dashboard (set matching ADMIN_SECRET in Supabase secrets)
# VITE_ADMIN_PASSWORD=your-admin-password
# VITE_ADMIN_SECRET=your-admin-secret
